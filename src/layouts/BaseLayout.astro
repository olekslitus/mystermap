---
import '~/styles/global.css';

interface Props {
  title: string;
  description?: string;
  fullBleed?: boolean;
}

const { title, description = "Map of the United States, controlled by supernatural forces.", fullBleed = false } = Astro.props;

const pageTitle = title === 'MysterMap' ? title : `${title} · MysterMap`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&display=swap" />
  <title>{pageTitle}</title>
  <script is:inline>
    (function () {
      var saved = localStorage.getItem('mm-theme');
      var preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      document.documentElement.dataset.theme = saved || preferred;
    })();
  </script>
</head>
<body class={fullBleed ? 'full-bleed' : ''}>
  <header class="site-header">
    <a class="site-title" href={import.meta.env.BASE_URL}>MysterMap</a>
    <nav class="site-nav">
      <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/about/`}>About</a>
      <a href="https://github.com/" rel="noopener">Contribute</a>
    </nav>
    <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Switch to light mode">☀</button>
  </header>
  <main>
    <slot />
  </main>
  <script>
    const toggle = document.getElementById('theme-toggle') as HTMLButtonElement;

    function syncToggle() {
      const isLight = document.documentElement.dataset.theme === 'light';
      toggle.textContent = isLight ? '🌙' : '☀';
      toggle.setAttribute('aria-label', isLight ? 'Switch to dark mode' : 'Switch to light mode');
    }

    toggle.addEventListener('click', () => {
      const next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
      document.documentElement.dataset.theme = next;
      localStorage.setItem('mm-theme', next);
      syncToggle();
    });

    syncToggle();
  </script>
</body>
</html>
