---
import BaseLayout from '~/layouts/BaseLayout.astro';
import MapIsland from '~/components/MapIsland.astro';
import { loadMapData } from '~/lib/loadMapData';

const data = await loadMapData(import.meta.env.BASE_URL);
---
<BaseLayout title="MysterMap" fullBleed>
  <MapIsland data={data} />
</BaseLayout>

<style is:global>
  body.full-bleed {
    overflow: hidden;
  }
  body.full-bleed main {
    height: 100vh;
    width: 100vw;
  }
</style>
